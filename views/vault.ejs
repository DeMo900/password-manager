<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your-valut</title>
    <link rel="stylesheet" href="./public/vault.css">
</head>
<body class="bg-bodyColor">
    <nav class="bg-bodyColor border-b-[0.2px] border-b-gray-700 h-[73px] flex items-center sticky top-0 px-4 sm:px-8 md:px-16">
  <div class="text-white font-bold text-sm sm:text-base md:text-lg">Password Master</div>
  <div class="flex gap-4 absolute left-1/2 -translate-x-1/2">
    <a href="/vault">
       <div class="text-slate-400 hover:text-white" id="vault">Vault</div>
    </a>
   <a href="/">
   <div class="text-slate-400 hover:text-white" id="generator">Generator</div>
   </a>
  </div>
  <div class="ml-auto flex gap-2 sm:gap-4 md:gap-6 items-center">
    <span class="border-l border-l-gray-700 pl-2 sm:pl-4 md:pl-8 mr-[-10px] hidden sm:block">
        <h2 class="text-white font-semibold text-xs sm:text-sm md:text-base" id="username"></h2>
        <p class="text-slate-400 font-thin text-xs sm:text-sm">Basic Plan</p>
    </span>
         <img src="./profile.svg" class="mr-2 sm:mr-4 w-6 sm:w-8 md:w-auto" alt="">
    <img src="./logout.svg" class="w-5 sm:w-6 md:w-auto cursor-pointer" alt="Logout" id="logout">
  </div>
</nav>
<div class="flex justify-between px-4">
<div class="mt-6 ml-12 ">
  <div class="text-3xl font-black mb-1 text-white">Vault</div>
  <div class="text-slate-400 font-semibold">Securely manage your 24 stored credentials</div>
</div>
<a href="/">
<button class="text-white font-bold  bg-blue-600 h-11 px-6  mr-8 mt-12 shadow-lg shadow-blue-500/20 rounded-md cursor-pointer hover:bg-blue-700 transition duration-200">+ Add new password</button>
</a>
</div>
<div class="flex items-center gap-4 px-4 ml-2 sm:px-12 mt-10 w-full">
  <div class="flex items-center gap-2 w-full bg-slate-800 rounded-2xl py-2 px-3">
    <img src="./search.svg" class="w-5 h-5 flex-shrink-0" alt="">
    <input id="search-input" type="search" placeholder="Search for a password by an app name...." class="h-10 w-full bg-slate-800 text-white placeholder:text-slate-400 focus:outline-none">
  </div>
  <div class="flex items-center bg-slate-800 rounded-lg">
    <img src="./sort.svg" class="w-11 h-6 absolute right-24 " alt="Sort">
  <summary class="bg-slate-800 list-none rounded-lg px-8 py-2 text-white hover:bg-slate-700 transition duration-200">Sort</summary>
  </div>
</div>
<div class="overflow-x-auto mt-8 rounded-xl border border-slate-700 mx-auto w-[90%] shadow">
  <table class="  w-[100%]  font-mono text-left ">
    <thead>
      <tr class=" bg-slate-800/50 text-slate-600 ">
        <th class="px-10 py-4 text-xs ">APPLICATION</th>
        <th class="px-24 py-4  text-xs">PASSWORD</th>
        <th class="px-24 py-4  text-xs">CREATED ON</th>
        <th class="px-24 py-4  text-xs ">ACTION</th>
      </tr>
    </thead>
    <tbody id="tbody">
      <tr>
        <td class="px-10 py-4 text-white">
          <div class="flex items-center gap-2">
            <img class="w-6 h-6 " src="./Github.png" alt="">
            <span >GITHUB</span>
          </div>
        </td>
        <td id="password" class="px-24 py-4 text-white">••••••••</td>
        <td class="text-white px-24 py-4">2024-01-01</td>
        <td class="px-24 py-4 text-red-500 cursor-pointer hover:text-red-600">
          <div class="flex justify-center gap-4 items-center">
            <img  src="./copy.svg" alt="Copy" class="hover:bg-slate-400/50 transition duration-300 border-left-2 copy-img ">
            <img src="./delete.png" alt="Delete" class="w-8 hover:bg-red-600/30 rounded-md transition duration-200 delete-img">
          </div>
        </td>
      </tr>
    </tbody>
    <tfoot class="h-16">
      <tr class="bg-slate-800/50 text-slate-300 ">
        <td colspan="4">
          <div class="flex justify-between items-center">
      <p class="ml-4">  Showing 1 to 10 of <span id="total-results"></span> results</p>
        <div class="flex justify-end gap-1 items-center " id="buttons">
     <button id="arrow-left-btn" class=" text-white px-4 py-1 w-14 rounded-md mr-2 hover:bg-slate-600 transition duration-200"><img id="arrow-left" src="./a-left.png" alt="Previous"></button>
   <div id="value">1</div>
       <button id="arrow-right-btn" class=" text-white px-4 py-1 w-14 rounded-md hover:bg-slate-600 transition duration-200"><img id="arrow-right" src="./a-right.png" alt="Next"></button>
        </div>
            </div>
        </td>
      </tr>
    </tfoot>
  </table>
</div>
<script src="./vault.js"></script>
</body>
</html>